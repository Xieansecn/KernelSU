--- a/arch/x86/include/asm/cpufeatures.h
+++ b/arch/x86/include/asm/cpufeatures.h
@@ -468,6 +468,7 @@
 #define X86_FEATURE_BHI_CTRL		(21*32+ 2) /* "" BHI_DIS_S HW control available */
 #define X86_FEATURE_CLEAR_BHB_HW	(21*32+ 3) /* "" BHI_DIS_S HW control enabled */
 #define X86_FEATURE_CLEAR_BHB_LOOP_ON_VMEXIT (21*32+ 4) /* "" Clear branch history at vmexit using SW loop */
+#define X86_FEATURE_INDIRECT_SAFE	(21*32+ 5) /* Synthetic gate for KernelSU syscall table dispatch */
 
 /*
  * BUG word(s)
diff --git a/arch/x86/include/asm/syscall.h b/arch/x86/include/asm/syscall.h
index e02b1b7..0fa8b36 100644
--- a/arch/x86/include/asm/syscall.h
+++ b/arch/x86/include/asm/syscall.h
@@ -19,6 +19,13 @@
 /* This is used purely for kernel/trace/trace_syscalls.c */
 typedef long (*sys_call_ptr_t)(const struct pt_regs *);
 extern const sys_call_ptr_t sys_call_table[];
+#if defined(CONFIG_X86_64) && defined(CONFIG_IA32_EMULATION)
+extern const sys_call_ptr_t ia32_sys_call_table[];
+#endif
+
+#ifdef CONFIG_X86_64
+extern bool x86_syscall_hardening_enabled;
+#endif
 
 /*
  * These may not exist, but still put the prototypes in so we
diff --git a/arch/x86/kernel/cpu/common.c b/arch/x86/kernel/cpu/common.c
index e3c6abe..b8aded7 100644
--- a/arch/x86/kernel/cpu/common.c
+++ b/arch/x86/kernel/cpu/common.c
@@ -276,6 +276,28 @@ static int __init x86_noinvpcid_setup(char *s)
 }
 early_param("noinvpcid", x86_noinvpcid_setup);
 
+#ifdef CONFIG_X86_64
+bool x86_syscall_hardening_enabled __ro_after_init = true;
+
+static int __init x86_syscall_hardening_setup(char *str)
+{
+	if (!str)
+		return -EINVAL;
+
+	if (!strcmp(str, "off")) {
+		x86_syscall_hardening_enabled = false;
+		pr_info("syscall_hardening: direct syscall dispatch disabled\n");
+		return 0;
+	}
+
+	if (!strcmp(str, "on"))
+		return 0;
+
+	return -EINVAL;
+}
+early_param("syscall_hardening", x86_syscall_hardening_setup);
+#endif
+
 #ifdef CONFIG_X86_32
 static int cachesize_override = -1;
 static int disable_x86_serial_nr = 1;
@@ -2419,6 +2441,7 @@ void __init arch_cpu_finalize_init(void)
 		print_cpu_info(&boot_cpu_data);
 	}
 
+	setup_force_cpu_cap(X86_FEATURE_INDIRECT_SAFE);
 	cpu_select_mitigations();
 
 	arch_smt_update();
